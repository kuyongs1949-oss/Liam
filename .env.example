# ──────────────────────────────────────────────
# Backend (Render에서 자동 주입됨)
# ──────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# Render에서 noise-calculator 서비스 URL이 자동으로 주입됨
CALCULATOR_URL=https://noise-calculator.onrender.com

# (선택) PostgreSQL - 추후 DB 기능 추가 시
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# (선택) Redis - 캐싱 비활성화 시 자동 무시됨
# REDIS_URL=redis://...

# ──────────────────────────────────────────────
# Frontend (Vercel 대시보드에서 설정)
# ──────────────────────────────────────────────
# Render Backend URL로 변경 필요
VITE_API_BASE_URL=https://noise-backend.onrender.com/api
VITE_MAP_CENTER_LAT=37.5665
VITE_MAP_CENTER_LNG=126.9780

# ──────────────────────────────────────────────
# 로컬 개발용
# ──────────────────────────────────────────────
# NODE_ENV=development
# PORT=3001
# DATABASE_URL=postgresql://noise_user:noise_pass@localhost:5432/noise_assessment
# REDIS_URL=redis://localhost:6379
# CALCULATOR_URL=http://localhost:8000
# VITE_API_BASE_URL=http://localhost:3001/api
